{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-stdin",
    "shell:allow-kill",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load"
  ]
}
